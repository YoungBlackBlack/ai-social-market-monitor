# Copy to .env and fill in real values. .env is gitignored.

# Exa Search API key (required for all Exa scripts).
EXA_API_KEY=your-exa-api-key

# Feishu custom-bot webhook for alert notifications (optional).
# Create one in the target group: 设置 → 群机器人 → 添加机器人 → 自定义机器人.
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# Only set if the bot has "签名校验" (signature verification) enabled.
FEISHU_WEBHOOK_SECRET=

# Optional runtime settings for hosted deployments such as Railway.
# Mount a Railway volume and point STATE_DIR at it if you want monitor history,
# exports, snapshots, and SQLite output to survive restarts/redeploys.
STATE_DIR=/data/ai-social-market-monitor
SCHEDULE_TIMEZONE=Asia/Shanghai
MONITOR_CRON=0 9 * * *
FULL_REBUILD_CRON=30 9 * * 1
ENABLE_SCHEDULER=true
RUN_MONITOR_ON_STARTUP=true
ENABLE_FULL_REBUILD=true

# Keep this false on Railway if you do not want Playwright/Chromium there.
ENABLE_BROWSER_VALIDATION=false
